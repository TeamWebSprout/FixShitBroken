# --- Supabase (app reads via the anon key; the worker writes via service role) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Never exposed to the browser. Used by the ingestion worker and
# any server action that must bypass row-level security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection string for the worker (Supabase > Project Settings >
# Database > Connection string > URI). Used by node-pg in the ingestion worker.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres

# --- External data APIs (Phase 1) ---
# Free key: https://api.congress.gov/sign-up/
CONGRESS_GOV_API_KEY=
