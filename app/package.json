    "build:embeds": "node worker/build-embeds.mjs",
    "build:site:full": "node worker/ingest-legislators.mjs --dry-run && node worker/summarize-bills.mjs --from-votes && node worker/build-embeds.mjs && node worker/generate-rep-pages.mjs"
